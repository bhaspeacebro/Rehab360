{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Rehab360 mainApp",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/pose_tracking/mainApp.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": false
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "c:/Users/bhask/rehab_motion_feedback/Rehab360",
      "program": "c:/Users/bhask/rehab_motion_feedback/Rehab360/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}